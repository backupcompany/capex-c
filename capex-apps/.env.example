# =============================================================================
# CAPEX Frontend (capex-apps) — copy to .env.local
#   cp .env.example .env.local
# Restart `npm run dev` after changes.
# =============================================================================

# --- Backend BFF (capexbe) — REQUIRED ------------------------------------------
# Local: http://localhost:3001
# Prod:  https://your-api.example.com (no trailing slash)
NEXT_PUBLIC_CAPEXBE_URL=http://localhost:3001

# Server-side proxy fallback (optional; NEXT_PUBLIC_CAPEXBE_URL is preferred)
# CAPEXBE_URL=http://localhost:3001

# Edge middleware JWT verify — same value as capexbe JWT_ACCESS_SECRET (never NEXT_PUBLIC_*)
# Enables signature check at Next.js edge before /api/be proxy. Optional in local dev.
# JWT_ACCESS_SECRET=change-me-use-openssl-rand-base64-48

# --- Security flags (recommended) --------------------------------------------
# All data + auth session via capexbe httpOnly cookies
NEXT_PUBLIC_USE_BACKEND_SESSION=true

# Public demo — restrict to comma-separated client IPs (server-side; empty = allow all)
# IP_ALLOWLIST=203.0.113.10,203.0.113.11

# Microsoft SSO via backend OAuth (disable for password-only testing)
NEXT_PUBLIC_ENABLE_AZURE_SSO=true

# --- Optional / dev only -----------------------------------------------------
# Demo LAN preview (/sabet) — password login, relaxed rate limits, any role OK
# NEXT_PUBLIC_CAPEX_DEMO_MODE=true
# NEXT_PUBLIC_AUTH_DEBUG=true
# NEXT_PUBLIC_PROJECT_LIST_DEBUG=1

# AI (Gemini) — server-only if enabled; NEVER NEXT_PUBLIC_GEMINI_API_KEY
# GEMINI_API_KEY=

# Azure OAuth + Supabase Auth gateway — configure on capexbe ONLY (never NEXT_PUBLIC_*)
# See capexbe/.env.example (SUPABASE_URL, SUPABASE_ANON_KEY, FRONTEND_URL)
