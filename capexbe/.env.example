# =============================================================================
# CAPEX Backend (capexbe) — copy to .env
#   cp .env.example .env
# =============================================================================

NODE_ENV=development
PORT=3001

# --- Supabase (Dashboard → Project Settings → API) ---------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# REQUIRED in production — server-side DB access + auth_sessions writes
# NEVER expose this in frontend / NEXT_PUBLIC_* / Docker build-args for capex-web
SUPABASE_SERVICE_ROLE_KEY=

# REQUIRED for POST /auth/exchange
# Dashboard → Project Settings → API → JWT Settings → JWT Secret
# Do NOT reuse JWT_ACCESS_SECRET or anon key here.
SUPABASE_JWT_SECRET=

# --- Backend session JWT (httpOnly cookie capex_access) ------------------------
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-use-openssl-rand-base64-48
JWT_SECRET=

# --- CORS (comma-separated, no spaces) ---------------------------------------
# Local dev:
CORS_ORIGINS=http://localhost:3000
# Production example:
# CORS_ORIGINS=https://capex.siloamhospitals.com

# Public frontend origin — OAuth callback redirect (defaults to first CORS_ORIGIN)
# FRONTEND_URL=http://localhost:3000

# Add to Supabase Dashboard → Auth → URL Configuration → Redirect URLs:
#   {FRONTEND_URL}/api/auth/azure/callback

# --- Security / audit ----------------------------------------------------------
ENABLE_AUTH_AUDIT_LOG=true

# Public exposure — comma-separated client IPs (empty = allow all; localhost always OK)
# IP_ALLOWLIST=203.0.113.10,203.0.113.11

# Demo LAN preview (/sabet) — password login + allow 192.168.x.x CORS
# CAPEX_DEMO_MODE=true

# SSO-only production: password login disabled when NODE_ENV=production. Override:
# DISABLE_PASSWORD_LOGIN=false

# --- Optional ------------------------------------------------------------------
# Corporate TLS (Windows proxy / custom CA)
# SUPABASE_CA_CERT_PATH=/path/to/corporate-root-ca.pem

# Redis shared cache — start locally: make redis-up
# Also backs auth rate limit, account lockout, and global API throttler (400/min)
REDIS_URL=redis://127.0.0.1:6379

# PERF_CACHE_LOG=1
# PROJECT_LIST_PIPELINE_LOG=1

# HTTP performance (optional)
# COMPRESSION_THRESHOLD=1024
# SLOW_REQUEST_MS=1000
# REQUEST_METRICS_LOG=0

# GET /metrics — localhost-only by default in prod; remote scrape needs header:
# curl -H "X-Metrics-Token: $METRICS_SECRET" https://host/metrics
# METRICS_SECRET=
# METRICS_PUBLIC=1   # dev only — never set in production

# Auth lockout — 5 failures / 15 min → 15 min block (email+IP key)
# AUTH_LOCKOUT_MAX_FAILURES=5
# AUTH_LOCKOUT_WINDOW_MS=900000
# AUTH_LOCKOUT_MS=900000
# AUTH_LOCKOUT_DISABLED=1   # dev/demo only

# Logging — async pino (nestjs-pino)
# LOG_LEVEL=info
# PINO_PRETTY=0
