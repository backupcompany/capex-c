.cursor/mcp.json

# OS
.DS_Store

# Env secrets (all apps) — never commit credentials
.env
.env.*
.env.local
.env.*.local
**/.env
**/.env.*
**/.env.local
**/.env.*.local
!**/.env.example
!.env.example

# Dependencies
**/node_modules/

# Build outputs
**/.next/
**/out/
**/dist/
**/build/
**/.netlify/
**/coverage/

# Logs & debug
**/*.log
**/.pnpm-debug.log*

# TypeScript
**/*.tsbuildinfo
**/next-env.d.ts

# Ops data — never commit credentials or user imports
**/scripts/*.data.json
**/scripts/*-users.json

# IDE
**/.idea/
**/.vscode/*
!**/.vscode/settings.json
